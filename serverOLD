const app = express()
app.use(express.json())
app.use(express.urlencoded({extended: false}))

app.set('view engine','ejs')
app.use(express.static("public"))


app.get("/home",(req,res)=>{
    res.render("home")
})
app.get("/",(req,res)=>{
    res.render("login")
})
app.get("/signup",(req,res)=>{
    res.render("signup")
})
app.post("/signup",async (req,res)=>{
    const data = {
        name: req.body.username,
        password: req.body.password
    }
    const existingUser = await collection.findOne({name: data.name})
    if(existingUser){
        res.send({data:"user already exists. Please choose a different name."})
    }
    else{
        const saltRounds = 37
        const hashedPassword = await bcrypt.hash(data.password, saltRounds)
        data.password = hashedPassword

        const userdata = await collection.insertMany(data)
        console.log(userdata)
    }
    
})

app.post("/login",async (req,res)=>{
    try{
        const check = await collection.findOne({name: req.body.username})
        if(!check){
            res.send({data:"user name was not found"})
        }
        const isPasswordMath = await bcrypt.compare(req.body.password, check.password)
        if(isPasswordMath){
            res.render("home")
        }else{
            res.send({data:"wrong password"})
        }
    }catch{
        res.send({data:"wrong detail"})
    }
})


